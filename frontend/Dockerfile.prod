# syntax=docker/dockerfile:1
# Сборка Vite SPA и Nginx. Контекст сборки — корень репозитория (см. docker-compose.prod.yml).

FROM node:22-alpine AS spa-build
WORKDIR /spa
COPY frontend/spa/package.json frontend/spa/package-lock.json ./
RUN npm ci
COPY frontend/spa/ ./
RUN npm run build

FROM nginx:alpine
COPY frontend/nginx.conf /etc/nginx/nginx.conf
COPY --from=spa-build /spa/dist /usr/share/nginx/html/
EXPOSE 80
