# Окружение приложения: development | staging | production
APP_ENV=development

# Режим отладки (подробные логи SQL и т.п.)
APP_DEBUG=true

# URI PostgreSQL для async SQLAlchemy (драйвер asyncpg)
# Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
POSTGRES_URI=postgresql+asyncpg://sales:sales@postgres:5432/sales_agent

# URI Redis (память диалогов; БД 0)
REDIS_URI=redis://redis:6379/0

# Celery: отдельные индексы Redis от чата (1 = брокер, 2 = backend результатов)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# TTL истории диалога в Redis (секунды), по умолчанию 24 ч
# CHAT_MEMORY_TTL_SECONDS=86400

# Каталог для WAV записей голосовых сессий (стерео: слева пользователь, справа бот). Пусто — не сохранять.
# В Docker Compose обычно /app/data/recordings (том ./data/recordings).
# CALL_RECORDINGS_DIR=data/recordings

# MAX Messenger: вкл/выкл long polling — в панели «Настройки» (system_settings MAX_USE_POLLING), не через .env.
# Webhook и polling одновременно по правилам MAX нельзя.
# MAX_USE_POLLING в .env не останавливает воркер (см. README).
# Необязательно: базовый URL Platform API (отправка сообщений и long polling /updates)
# MAX_PLATFORM_API_BASE=https://platform-api.max.ru
# Устаревшее имя (на код отправки не влияет):
# MAX_API_BASE=https://api.max.ru
# Токен бота MAX (из кабинета MAX). Если задан здесь — используется, когда в БД пусто; значение в панели «Настройки» имеет приоритет.
# MAX_BOT_TOKEN=
# Групповые чаты (фаза 17): MAX_BOT_USERNAME, MAX_GROUP_CHAT_ID, MAX_GROUP_ADDITIONAL_PROMPT — только в панели «Настройки» / system_settings (см. README).

# OpenAI API (опционально; без ключа адаптеры возвращают заглушки)
# OPENAI_API_KEY=

# Голос (Pipecat): STT — deepgram или salutespeech (Сбер SmartSpeech)
# VOICE_STT_PROVIDER=salutespeech
# DEEPGRAM_API_KEY=

# SaluteSpeech (фаза 13): Authorization Key из Studio; scope как в проекте (часто SALUTE_SPEECH_PERS)
# VOICE_STT_PROVIDER=salutespeech
# VOICE_TTS_PROVIDER=salutespeech
# SALUTESPEECH_AUTH_KEY=
# SALUTESPEECH_SCOPE=SALUTE_SPEECH_PERS
# SALUTESPEECH_VOICE=Ost_24000
# wss:// по умолчанию — см. README; при смене эндпоинта:
# STT/TTS: gRPC на smartspeech.sber.ru (TLS). Целевой хост:порт — часто :443, при необходимости :8443
# SALUTESPEECH_GRPC_TARGET=smartspeech.sber.ru:443
# (SALUTESPEECH_REST_BASE_URL / WS — устарели для голоса; OAuth по-прежнему HTTP)
# URL OAuth (по умолчанию ngw.devices.sberbank.ru:9443); при обрыве TLS — VPN/файрвол или свой прокси
# SALUTESPEECH_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# SALUTESPEECH_OAUTH_RETRIES=3
# Учитывать HTTP(S)_PROXY из окружения (корпоративный прокси); в Docker Desktop часто оставляют false
# SALUTESPEECH_OAUTH_TRUST_ENV=false
# Проверка TLS к ngw/smartspeech (на VPS без корней Минцифры часто false)
# SALUTESPEECH_OAUTH_VERIFY_SSL=false
# SALUTESPEECH_SMARTSPEECH_VERIFY_SSL=false

# TTS: по умолчанию OpenAI (нужен OPENAI_API_KEY). Альтернатива — elevenlabs (HTTP) или salutespeech
# VOICE_TTS_PROVIDER=openai
# OPENAI_TTS_VOICE=alloy
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Язык распознавания Deepgram (код Pipecat Language, напр. ru, en)
# VOICE_STT_LANGUAGE=ru

# Bitrix24: полный URL входящего вебхука для метода crm.lead.add (без .json в конце — httpx шлёт JSON)
# BITRIX24_WEBHOOK_URL=https://ваш-портал.bitrix24.ru/rest/1/xxxxxxxx/crm.lead.add

# SIP (транк MCN.ru) — подстановка в Asterisk pjsip при старте контейнера (docker compose)
# Хост регистрации (FQDN или IP), как в ЛК оператора
# SIP_SERVER_IP=sip.mcn.ru
# IP или CIDR серверов оператора для identify (если не задан — берётся SIP_SERVER_IP; для FQDN укажите IP явно)
# SIP_OPERATOR_IP=203.0.113.10
# SIP_USER=
# SIP_PASSWORD=

# Asterisk ARI (контейнер asterisk в docker-compose; из web — http://asterisk:8088/ari)
# ASTERISK_URL=http://asterisk:8088/ari
# ASTERISK_ARI_USER=voiceai
# ASTERISK_ARI_PASSWORD=voiceai_secret
# ASTERISK_STASIS_APP=voice_ai_app
# Куда Asterisk шлёт RTP externalMedia (Docker DNS-имя сервиса с приложением)
# ASTERISK_RTP_ADVERTISE_HOST=web
# ASTERISK_RTP_PORT_MIN=18000
# ASTERISK_RTP_PORT_MAX=18015
