# Окружение приложения: development | staging | production
APP_ENV=development

# --- docker-compose.prod.yml: публикация контейнера frontend (Nginx+SPA) ---
# С хостовым Nginx + Certbot оставьте по умолчанию: bind 127.0.0.1:8080 → proxy_pass http://127.0.0.1:8080
# FRONTEND_BIND=127.0.0.1
# FRONTEND_HTTP_PORT=8080
# Без хостового прокси (панель сразу на :80 всех интерфейсов): FRONTEND_BIND=0.0.0.0 FRONTEND_HTTP_PORT=80

# Режим отладки (подробные логи SQL и т.п.)
APP_DEBUG=true

# Портал: секрет подписи JWT. В Docker с APP_ENV=production обязательно задать СВОЙ длинный случайный ключ
# (иначе контейнер web не поднимется: «В production задайте безопасный PORTAL_JWT_SECRET»).
# Нельзя оставлять dev-portal-jwt-secret-change-me. Пример генерации:
#   openssl rand -hex 32
# PORTAL_JWT_SECRET=
# Срок жизни токена панели в минутах (по умолчанию 1440 = 24 ч)
# PORTAL_JWT_EXPIRE_MINUTES=1440

# МИС: личный кабинет пациента через Mini App MAX (JWT подписывается тем же PORTAL_JWT_SECRET)
# MIS_PATIENT_JWT_EXPIRE_MINUTES=10080
# Допустимый возраст поля auth_date в initData (секунды)
# MIS_MAX_INIT_DATA_MAX_AGE_SEC=3600
# Базовый URL мини-приложения для текста /start reg_org_<uuid>_doc_<uuid> в боте (опционально)
# MIS_MAX_PATIENT_MINI_APP_BASE_URL=https://example.com/mis/max-app
# Публичный URL фронта для ссылок из бота MAX на /public/mis/patient/{id} (без завершающего слэша)
# MIS_PATIENT_PUBLIC_BASE_URL=https://example.com

# Часовой пояс пользователей и групповых чатов (IANA). Celery Beat и триггеры расписания ориентируются на это время.
# По умолчанию Саратов (UTC+4). В Docker/Postgres внутри по-прежнему хранятся моменты времени корректно (timestamptz).
APP_TIMEZONE=Europe/Saratov

# URI PostgreSQL для async SQLAlchemy (драйвер asyncpg)
# Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
POSTGRES_URI=postgresql+asyncpg://sales:sales@postgres:5432/sales_agent

# Шифрование секретов интеграций (REST /api/v1/integrations). Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# INTEGRATION_FERNET_KEY=

# URI Redis (память диалогов; БД 0)
REDIS_URI=redis://redis:6379/0

# Celery: отдельные индексы Redis от чата (1 = брокер, 2 = backend результатов)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# TTL истории диалога в Redis (секунды), по умолчанию 24 ч
# CHAT_MEMORY_TTL_SECONDS=86400

# Каталог для WAV записей голосовых сессий (стерео: слева пользователь, справа бот). Пусто — не сохранять.
# В Docker Compose обычно /app/data/recordings (том ./data/recordings).
# CALL_RECORDINGS_DIR=data/recordings
#
# Файлы на диске: витрины магазинов и логотипы сайтов Mini App. В проде (docker-compose.prod.yml) — именованные тома;
# без томов данные пропадут при пересоздании контейнера.
# SHOP_UPLOAD_DIR=/app/data/shop_uploads
# SITE_UPLOAD_DIR=/app/data/site_uploads

# MAX Messenger: вкл/выкл long polling — в панели «Настройки» (system_settings MAX_USE_POLLING), не через .env.
# Webhook и polling одновременно по правилам MAX нельзя.
# MAX_USE_POLLING в .env не останавливает воркер (см. README).
# Необязательно: базовый URL Platform API (отправка сообщений и long polling /updates)
# MAX_PLATFORM_API_BASE=https://platform-api.max.ru
# Устаревшее имя (на код отправки не влияет):
# MAX_API_BASE=https://api.max.ru
# Токен бота MAX (из кабинета MAX). Если задан здесь — используется, когда в БД пусто; значение в панели «Настройки» имеет приоритет.
# MAX_BOT_TOKEN=
# Опционально: ограничить long poll только этой организацией (отладка). По умолчанию поднимается по одному опросу /updates на каждый уникальный MAX_BOT_TOKEN (глобальный + все организации). Вебхук сам выбирает организацию по user_id бота.
# MAX_LONG_POLL_ORGANIZATION_ID=
# Telegram Bot API: уведомления продавцу из витрины магазина (если не задано в панели «Настройки»).
# TELEGRAM_BOT_TOKEN=
# VK API (токен сообщества с правом messages): уведомления продавцу из витрины при заказе с темы VK.
# VK_API_ACCESS_TOKEN=
# Одноразово при переносе на новый VPS с тем же токеном и пустым Redis: число marker из ответа GET /updates (чтобы не обработать старую очередь повторно). После первого успешного опроса удалите из .env.
# MAX_POLL_MARKER_BOOTSTRAP=
# Групповые чаты MAX: MAX_BOT_USERNAME; доп. промпты по группам — MAX_GROUP_CHAT_PROMPTS (JSON в system_settings) или устаревшие MAX_GROUP_CHAT_ID + MAX_GROUP_ADDITIONAL_PROMPT. Панель: SPA «Роли и промпты».
# Входящие VoIP-звонки MAX (фаза 23): MAX_CALL_ANSWER_DELAY, MAX_CALL_GREETING_PHRASE — в панели / system_settings (миграция 021). Медиа: см. README (UDP, Docker).

# OpenAI API (опционально; без ключа адаптеры возвращают заглушки)
# OPENAI_API_KEY=

# Голос (Pipecat): STT — deepgram или salutespeech (Сбер SmartSpeech)
# VOICE_STT_PROVIDER=salutespeech
# DEEPGRAM_API_KEY=

# SaluteSpeech (фаза 13): Authorization Key из Studio; scope как в проекте (часто SALUTE_SPEECH_PERS)
# VOICE_STT_PROVIDER=salutespeech
# VOICE_TTS_PROVIDER=salutespeech
# SALUTESPEECH_AUTH_KEY=
# SALUTESPEECH_SCOPE=SALUTE_SPEECH_PERS
# SALUTESPEECH_VOICE=Ost_24000
# wss:// по умолчанию — см. README; при смене эндпоинта:
# STT/TTS: gRPC на smartspeech.sber.ru (TLS). Целевой хост:порт — часто :443, при необходимости :8443
# SALUTESPEECH_GRPC_TARGET=smartspeech.sber.ru:443
# (SALUTESPEECH_REST_BASE_URL / WS — устарели для голоса; OAuth по-прежнему HTTP)
# URL OAuth (по умолчанию ngw.devices.sberbank.ru:9443); при обрыве TLS — VPN/файрвол или свой прокси
# SALUTESPEECH_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# SALUTESPEECH_OAUTH_RETRIES=3
# Учитывать HTTP(S)_PROXY из окружения (корпоративный прокси); в Docker Desktop часто оставляют false
# SALUTESPEECH_OAUTH_TRUST_ENV=false
# Проверка TLS к ngw/smartspeech (на VPS без корней Минцифры часто false)
# SALUTESPEECH_OAUTH_VERIFY_SSL=false
# SALUTESPEECH_SMARTSPEECH_VERIFY_SSL=false

# TTS: по умолчанию OpenAI (нужен OPENAI_API_KEY). Альтернатива — elevenlabs (HTTP) или salutespeech
# VOICE_TTS_PROVIDER=openai
# OPENAI_TTS_VOICE=alloy
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Язык распознавания Deepgram (код Pipecat Language, напр. ru, en)
# VOICE_STT_LANGUAGE=ru

# Bitrix24: полный URL входящего вебхука для метода crm.lead.add (без .json в конце — httpx шлёт JSON)
# BITRIX24_WEBHOOK_URL=https://ваш-портал.bitrix24.ru/rest/1/xxxxxxxx/crm.lead.add
# Marketplace Server App (OAuth): установка POST /api/bitrix/install, события POST /api/bitrix/events
# Пошаговая настройка локального приложения с UI (раздел «Сценарии»): docs/BITRIX24_SCENARIOS_SETUP.md
# BITRIX24_OAUTH_CLIENT_ID=
# BITRIX24_OAUTH_CLIENT_SECRET=
# BITRIX24_APPLICATION_TOKEN=
# Публичный HTTPS-ориджин панели (после install иначе редирект может стать http:// за Nginx → Mixed Content в iframe Битрикс24)
# BITRIX24_PUBLIC_APP_ORIGIN=https://lotus-it.ru

# SIP (транк MCN.ru) — подстановка в Asterisk pjsip при старте контейнера (docker compose)
# Хост регистрации (FQDN или IP), как в ЛК оператора
# SIP_SERVER_IP=sip.mcn.ru
# IP или CIDR серверов оператора для identify (если не задан — берётся SIP_SERVER_IP; для FQDN укажите IP явно)
# SIP_OPERATOR_IP=203.0.113.10
# SIP_USER=
# SIP_PASSWORD=

# Asterisk ARI (контейнер asterisk в docker-compose; из web — http://asterisk:8088/ari)
# ASTERISK_URL=http://asterisk:8088/ari
# ASTERISK_ARI_USER=voiceai
# ASTERISK_ARI_PASSWORD=voiceai_secret
# ASTERISK_STASIS_APP=voice_ai_app
# Куда Asterisk шлёт RTP externalMedia (Docker DNS-имя сервиса с приложением)
# ASTERISK_RTP_ADVERTISE_HOST=web
# ASTERISK_RTP_PORT_MIN=18000
# ASTERISK_RTP_PORT_MAX=18015

# Панель «Логи»: произвольная строка; в UI вводится тот же токен, заголовок X-Admin-Logs-Token.
# В docker-compose.prod.yml смонтируйте /var/run/docker.sock в контейнер web (read-only).
# ADMIN_LOGS_TOKEN=
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# DOCKER_API_VERSION=1.41
